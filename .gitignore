# independent Python lab (own data cache, not needed by the bot)
strategy_lab/

# build artifact - rebuilt by every tick, never committed
report/vizdata.js
report/build.json
# T-Invest candles copied under report/ by build_vizdata for chart.html (baked on VPS into
# data/live_rf/candles, which IS committed; the report/ copy is a build artifact like vizdata.js)
report/rf_candles/

# engine runtime
data/auto_trade.lock
*.tmp

# live engine runtime (VPS): log, push-flag and instrument cache are local-only
data/live_real/tick_log.txt
data/live_real/.push_now
data/live_real/instruments.json
data/live_real/.git_sync_state
# env with real API keys must never appear in the tree
trading-live.env

# local shots/scratch
*.png.tmp

# VPS reference bundle - local-only, NEVER committed to the public repo
vps/
# defense-in-depth: secret files ignored anywhere in the tree
secrets.txt
vps_secrets.enc

# T-Invest tokens - local only, NEVER committed (defense vs 'git add -A' in deploy_site)
.secrets/

# assistant: local VPS address/key for tools/ask.ps1, and __pycache__
tools/ask.config.json
assistant/__pycache__/
**/__pycache__/

# RF-LIVE runtime (VPS): log/cache/lock are local-only; state json IS committed by live_rf_tick.sh
data/live_rf/tick_log.txt
data/live_rf/latency_log.csv
data/live_rf/dryrun_calls.log
data/live_rf/engine.lock
data/live_rf/instruments.json
data/live_rf/.git_sync_state

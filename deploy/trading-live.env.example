# /etc/trading-live.env - environment for the LIVE executor (systemd EnvironmentFile).
# Install: sudo cp trading-live.env.example /etc/trading-live.env
#          sudo chown root:root /etc/trading-live.env && sudo chmod 600 /etc/trading-live.env
# NEVER commit the filled file. The systemd unit reads it as root and passes vars to the service.

# Bybit API key: create as trade-only (Contract Orders + Positions), NO withdraw/transfer,
# IP-whitelisted to this VPS. Unified Trading Account.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Telegram alerts (token/chat from the old VPS bundle: vps/secrets/vps_secrets.enc)
TG_BOT_TOKEN=
TG_CHAT_ID=
# Second recipient - gets ONLY the RF-LIVE (futures) alert stream, not crypto.
# The person messages the same bot once, then GET
# https://api.telegram.org/bot<TG_BOT_TOKEN>/getUpdates -> message.chat.id (or @userinfobot).
# Empty = no second recipient (safe default).
TG_CHAT_ID_FUT=

# Git-publication watchdog (deploy/git_sync_watch.sh): alert if our state stops
# reaching GitHub (stuck pull/push => stale dashboard) for this long. Empty TG_* above
# silences it. Uncomment to override the defaults.
# GIT_ALERT_AFTER_MIN=30      # minutes of stalled publication before the first alert
# GIT_ALERT_REPEAT_MIN=120    # minutes between reminders while still stalled

# 1 = dry-run (read-only ticks, orders are logged as WOULD PLACE); 0 = REAL ORDERS
LIVE_DRYRUN=1

# ---- RF-LIVE contour (T-Invest / Т-Инвестиции, C3b futures+stocks) ----
# Токен: создать в личном кабинете Т-Инвестиций. Для Phase 1 достаточно READONLY-токена,
# боевой (full access) - только с Phase 3. НИКОГДА не коммитить заполненный файл.
TINVEST_TOKEN=
# id брокерского счёта (tinvest_selftest.ps1 -ReadOnly покажет список GetAccounts)
TINVEST_ACCOUNT_ID=
# dryrun = сигналы+WOULD CALL без заявок | sandbox = песочница | prod = РЕАЛЬНЫЕ ЗАЯВКИ
TINVEST_MODE=dryrun
# токен песочницы (Phase 2)
TINVEST_SANDBOX_TOKEN=
